#include <iostream>
using namespace std;

class Users { // Users class
private:
string name;
string password;

public:
void setLogin(string n, string p) {
name = n;
password = p;
}

public:
bool Login(string n, string p){ //Login function
    return (n == name && p == password);
}
};

