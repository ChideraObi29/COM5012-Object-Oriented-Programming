// Login Procedure
ASK "Enter Username:" -> username
ASK "Enter Password:" -> password

CREATE member AS Members
member.setLogin("member", "pword1")

CREATE librarian AS Librarians
librarian.setLogin("librarian", "pword2")

CREATE admin AS Administrators
admin.setLogin("admin", "pword3")

IF member.Login(username, password) THEN
    CALL member.memberInterface()
ELSE IF librarian.Login(username, password) THEN
    CALL librarian.librarianInterface()
ELSE IF admin.Login(username, password) THEN
    CALL admin.adminInterface()
ELSE
    SHOW "Login Failed"
END IF

